{
  "input_schema": {
    "type": "object",
    "required": ["request", "objective"],
    "properties": {
      "request": { "type": "string" },
      "objective": { "type": "string" },
      "memory_context": { "type": "string" }
    }
  },
  "output_schema": {
    "type": "object",
    "required": ["status", "scorecard_markdown", "recommendation"],
    "properties": {
      "status": { "type": "string", "enum": ["completed", "dry_run"] },
      "scorecard_markdown": { "type": "string" },
      "recommendation": { "type": "string", "enum": ["go", "test", "reject"] }
    }
  }
}
