{
  "output_schema": {
    "type": "object",
    "required": ["status", "summary", "file_excerpt_markdown", "files_reviewed", "evidence"],
    "properties": {
      "status": { "type": "string", "enum": ["completed", "partial"] },
      "summary": { "type": "string" },
      "file_excerpt_markdown": { "type": "string" },
      "files_reviewed": {
        "type": "array",
        "items": { "type": "string" }
      },
      "evidence": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  }
}
