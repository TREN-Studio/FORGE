{
    "output_schema":  {
                          "type":  "object",
                          "required":  [
                                           "status",
                                           "summary",
                                           "analysis_markdown",
                                           "files_reviewed",
                                           "evidence"
                                       ],
                          "properties":  {
                                             "status":  {
                                                            "type":  "string",
                                                            "enum":  [
                                                                         "completed",
                                                                         "partial"
                                                                     ]
                                                        },
                                             "summary":  {
                                                             "type":  "string"
                                                         },
                                             "analysis_markdown":  {
                                                                       "type":  "string"
                                                                   },
                                             "files_reviewed":  {
                                                                    "type":  "array",
                                                                    "items":  {
                                                                                  "type":  "string"
                                                                              }
                                                                },
                                             "evidence":  {
                                                              "type":  "array",
                                                              "items":  {
                                                                            "type":  "string"
                                                                        }
                                                          },
                                             "search_terms":  {
                                                                  "type":  "array",
                                                                  "items":  {
                                                                                "type":  "string"
                                                                            }
                                                              }
                                         }
                      },
    "id":  "codebase-analyzer",
    "tier":  1,
    "allowlist":  [
                      "operator",
                      "desktop",
                      "worker"
                  ],
    "trigger_rules":  [
                          "analyze code",
                          "review code",
                          "codebase",
                          "repo",
                          "repository",
                          "find bugs",
                          "inspect project"
                      ],
    "risk_class":  "read",
    "built_in":  true,
    "preconditions":  [
                          "workspace"
                      ],
    "visibility":  "always"
}
