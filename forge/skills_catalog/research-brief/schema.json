{
  "input_schema": {
    "type": "object",
    "required": ["request", "objective"],
    "properties": {
      "request": { "type": "string" },
      "objective": { "type": "string" },
      "memory_context": { "type": "string" }
    }
  },
  "output_schema": {
    "type": "object",
    "required": ["status", "brief_markdown", "key_questions"],
    "properties": {
      "status": { "type": "string", "enum": ["completed", "dry_run"] },
      "brief_markdown": { "type": "string" },
      "key_questions": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  }
}
