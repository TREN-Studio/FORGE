{
    "input_schema":  {
                         "type":  "object",
                         "required":  [
                                          "request",
                                          "objective"
                                      ],
                         "properties":  {
                                            "request":  {
                                                            "type":  "string"
                                                        },
                                            "objective":  {
                                                              "type":  "string"
                                                          },
                                            "prior_results":  {
                                                                  "type":  "object"
                                                              }
                                        }
                     },
    "output_schema":  {
                          "type":  "object",
                          "required":  [
                                           "status",
                                           "article_markdown",
                                           "publish_ready"
                                       ],
                          "properties":  {
                                             "status":  {
                                                            "type":  "string",
                                                            "enum":  [
                                                                         "completed",
                                                                         "dry_run"
                                                                     ]
                                                        },
                                             "article_markdown":  {
                                                                      "type":  "string"
                                                                  },
                                             "publish_ready":  {
                                                                   "type":  "boolean"
                                                               }
                                         }
                      },
    "id":  "seo-article-writer",
    "tier":  1,
    "allowlist":  [
                      "operator",
                      "desktop",
                      "worker"
                  ],
    "trigger_rules":  [
                          "seo",
                          "article",
                          "blog",
                          "write article",
                          "content generation"
                      ],
    "risk_class":  "write",
    "built_in":  true,
    "preconditions":  [
                          "request",
                          "objective"
                      ],
    "visibility":  "on_request"
}
