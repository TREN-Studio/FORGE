                                                           },
                                            "method":  {
                                                           "type":  "string",
                                                           "enum":  [
                                                                        "POST",
                                                                        "PUT",
                                                                        "PATCH"
                                                                    ]
                                                       },
                                            "objective":  {
                                                              "type":  "string"
                                                          }
                                        },
                         "type":  "object",
                         "required":  [
                                          "request",
                                          "objective"
                                      ]
                     },
    "id":  "external-publisher",
    "tier":  2,
    "allowlist":  [
                      "operator",
                      "desktop",
                      "worker"
                  ],
    "trigger_rules":  [
                          "publish",
                          "send",
                          "post",
                          "upload",
                          "submit",
                          "webhook",
                          "external endpoint"
                      ],
    "risk_class":  "publish",
