                                                                           "type":  "string"
                                                                       },
                                             "target_url":  {
                                                                "type":  "string"
                                                            },
                                             "summary":  {
                                                             "type":  "string"
                                                         },
                                             "status":  {
                                                            "type":  "string",
                                                            "enum":  [
                                                                         "completed",
                                                                         "dry_run"
                                                                     ]
                                                        },
                                             "published_bytes":  {
                                                                     "type":  "number"
                                                                 }
                                         },
                          "type":  "object",
                          "required":  [
                                           "status",
                                           "target_url",
                                           "response_status",
                                           "response_body_preview",
                                           "published_bytes"
                                       ]
                      },
    "input_schema":  {
                         "properties":  {
