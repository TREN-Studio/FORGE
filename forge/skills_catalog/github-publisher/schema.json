{
  "input_schema": {
    "type": "object",
    "required": ["request", "objective"],
    "properties": {
      "request": { "type": "string" },
      "objective": { "type": "string" },
      "target_repo": { "type": "string" },
      "repo_path": { "type": "string" },
      "branch": { "type": "string" },
      "commit_message": { "type": "string" },
      "content": { "type": "string" }
    }
  },
  "output_schema": {
    "type": "object",
    "required": ["status", "repository", "repo_path", "branch", "response_status", "published_bytes"],
    "properties": {
      "status": { "type": "string", "enum": ["completed", "dry_run"] },
      "repository": { "type": "string" },
      "repo_path": { "type": "string" },
      "branch": { "type": "string" },
      "commit_sha": { "type": "string" },
      "content_url": { "type": "string" },
      "response_status": { "type": "number" },
      "published_bytes": { "type": "number" },
      "summary": { "type": "string" }
    }
  }
}
