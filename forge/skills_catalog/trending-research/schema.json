{
    "input_schema": {
        "type": "object",
        "required": ["request", "objective"],
        "properties": {
            "request": { "type": "string" },
            "objective": { "type": "string" },
            "niche": { "type": "string" },
            "limit": { "type": "integer", "minimum": 1, "maximum": 50 }
        }
    },
    "output_schema": {
        "type": "object",
        "required": ["status", "google_trends", "amazon_bsr", "combined_insights"],
        "properties": {
            "status": { "type": "string", "enum": ["completed", "partial", "dry_run", "failed"] },
            "google_trends": { "type": "array", "items": { "type": "object" } },
            "amazon_bsr": { "type": "array", "items": { "type": "object" } },
            "combined_insights": { "type": "string" },
            "error": { "type": "string" }
        }
    },
    "id": "trending-research",
    "tier": 1,
    "allowlist": ["operator", "desktop", "worker"],
    "trigger_rules": [
        "trend", "trending", "google trends", "amazon bsr", "best seller",
        "popular", "viral", "what's hot", "market research",
        "keyword research", "niche research", "products",
        "اتجاهات", "رائج", "الأكثر مبيعاً", "بحث كلمات مفتاحية"
    ],
    "risk_class": "read",
    "built_in": true,
    "preconditions": ["request", "objective"],
    "visibility": "always"
}
